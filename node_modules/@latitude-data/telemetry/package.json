{
  "name": "@latitude-data/telemetry",
  "version": "3.3.0",
  "description": "Latitude Telemetry for TypeScript",
  "author": "Latitude Data SL <hello@latitude.so>",
  "license": "MIT",
  "keywords": [
    "AI",
    "Telemetry",
    "sdk",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/latitude-dev/latitude-llm/tree/main/packages/telemetry/typescript"
  },
  "homepage": "https://github.com/latitude-dev/latitude-llm/tree/main/packages/telemetry/typescript#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/context-async-hooks": "2.7.1",
    "@opentelemetry/core": "2.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.213.0",
    "@opentelemetry/instrumentation": "0.213.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-node": "2.7.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@traceloop/instrumentation-anthropic": "0.27.0",
    "@traceloop/instrumentation-bedrock": "0.26.0",
    "@traceloop/instrumentation-cohere": "0.26.0",
    "@traceloop/instrumentation-langchain": "0.25.0",
    "@traceloop/instrumentation-llamaindex": "0.25.0",
    "@traceloop/instrumentation-openai": "0.27.0",
    "@traceloop/instrumentation-together": "0.25.0",
    "@traceloop/instrumentation-vertexai": "0.26.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "3.0.53",
    "@ai-sdk/openai7": "npm:@ai-sdk/openai@4.0.0-beta.74",
    "@ai-sdk/otel": "1.0.0-beta.127",
    "@anthropic-ai/sdk": "0.104.1",
    "@aws-sdk/client-bedrock-runtime": "3.1036.0",
    "@biomejs/biome": "2.4.6",
    "@google-cloud/vertexai": "1.12.0",
    "@langchain/core": "1.1.41",
    "@langchain/openai": "1.4.4",
    "@llamaindex/openai": "0.4.23",
    "@llamaindex/workflow": "1.1.25",
    "@openai/agents": "0.11.6",
    "@types/node": "22.14.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "ai": "6.0.168",
    "ai7": "npm:ai@7.0.0-beta.181",
    "cohere-ai": "7.21.0",
    "llamaindex": "0.12.1",
    "openai": "6.42.0",
    "tsdown": "0.21.9",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "zod": "4.3.6"
  },
  "scripts": {
    "build": "tsdown",
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --pool=forks --passWithNoTests --dir src"
  }
}